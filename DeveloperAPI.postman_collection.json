          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": 1,\n  \"name\": \"Jane Smith\",\n  \"department\": \"Frontend\",\n  \"stacks\": [\"React\", \"TypeScript\", \"CSS\"]\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/v1/developer/update",
